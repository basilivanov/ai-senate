{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "cliproxy": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "CLI Proxy (local)",
      "options": {
        "baseURL": "http://127.0.0.1:18317/v1"
      },
      "models": {
        "claude-opus-4-6-thinking": {},
        "claude-sonnet-4-6": {},
        "gemini-3-flash-agent": {},
        "gpt-5.4": {},
        "gpt-5.4-mini": {}
      }
    }
  },
  "agent": {
    "glm51": {
      "model": "opencode-go/glm-5.1",
      "prompt": "{file:./agents/glm51.md}"
    },
    "qwen37max": {
      "model": "opencode-go/qwen3.7-plus",
      "prompt": "{file:./agents/qwen37max.md}"
    },
    "minimax": {
      "model": "opencode-go/minimax-m3",
      "prompt": "{file:./agents/minimax.md}"
    },
    "deepseekv4pro": {
      "model": "opencode-go/deepseek-v4-pro",
      "prompt": "{file:./agents/deepseekv4pro.md}"
    },
    "plan": {
      "model": "cliproxy/claude-sonnet-4-6",
      "prompt": "Ты — аналитик-рецензент. Не используй инструменты. Верни только валидный JSON."
    }
  },
  "permission": {
    "edit": "allow",
    "bash": "allow",
    "webfetch": "allow"
  }
}